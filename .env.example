# FOUND-02 — copy to .env and fill for Firefly III API access (Phase 2+).
# Never commit .env; token stays server-side only.

# Base URL of your Firefly III instance (trailing slash optional)
FIREFLY_BASE_URL=

# Personal access token from Firefly III (Profile → OAuth / Personal access tokens)
FIREFLY_API_TOKEN=

# Comma-separated browser origins allowed to call the API (CORS)
# Example: https://analytics.example.com,http://localhost:5174
CORS_ALLOWED_ORIGINS=https://analytics.example.com

# --- OpenRouter (AI categorization — Phase 10+) ---
# Optional: when empty, AI suggest endpoints are disabled
OPENROUTER_API_KEY=
# Default model for categorization suggestions
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- FF3Analytics automation ---
# Firefly rule group name for AI-created rules (Phase 13)
FF3ANALYTICS_RULE_GROUP=FF3Analytics AI
# Host path bind-mounted to /data in the backend container (SQLite sidecar).
# Internal container path is /data (set in the backend image; do not configure here).
FF3ANALYTICS_DATA_PATH=./data
# UID/GID the backend runs as; SQLite files are created with this ownership
PUID=1000
PGID=1000
# forward-only loan split queue start date (LOAN-07)
FF3ANALYTICS_LOAN_SPLITS_SINCE=2026-07-01
# In-process TTL (seconds) for cached Firefly accounts, categories, and budgets (default 7200)
FIREFLY_REFERENCE_CACHE_TTL_SECONDS=7200
# Tag applied to journals after loan split apply
FF3ANALYTICS_LOAN_TAG=loan-split
# Tag applied on AI categorization writes and AI-created rules (default ai-categorized)
FF3ANALYTICS_AI_TAG=ai-categorized

