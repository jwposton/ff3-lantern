# FOUND-02 — copy to .env and fill for Firefly III API access (Phase 2+).
# Never commit .env; token stays server-side only.

# Base URL of your Firefly III instance (trailing slash optional)
FIREFLY_BASE_URL=

# Personal access token from Firefly III (Profile → OAuth / Personal access tokens)
FIREFLY_API_TOKEN=

# Comma-separated browser origins allowed to call the API (CORS)
# Example: https://analytics.example.com,http://localhost:5174
CORS_ALLOWED_ORIGINS=https://analytics.example.com

# --- OpenRouter (AI categorization — Phase 10+) ---
# Optional: when empty, AI suggest endpoints are disabled
OPENROUTER_API_KEY=
# Default model for categorization suggestions
OPENROUTER_MODEL=openai/gpt-4o-mini

# --- FF3Analytics automation ---
# Firefly rule group name for AI-created rules (Phase 13)
FF3ANALYTICS_RULE_GROUP=FF3Analytics AI
# SQLite sidecar data directory (./data local, /data in Docker)
FF3ANALYTICS_DATA_DIR=./data

